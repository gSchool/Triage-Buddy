# Copy this file to .env and fill in your key(s). .env is git-ignored.
# Keys are only needed if that LLM is used as a provider
GROQ_API_KEY=
GEMINI_API_KEY=
ZAI_API_KEY=
# Optional: override the current provider's default model id (DEFAULT_MODEL otherwise).
TRIAGE_MODEL=
# labproxy: an unauthenticated classroom/lab proxy speaking the Anthropic
# /v1/messages shape (may serve a non-Claude model regardless of what's
# requested) — lab/experiment use only, never real patient input.
LABPROXY_BASE_URL=
LABPROXY_STUDENT_ID=
LABPROXY_API_KEY=
# ollama: a local Ollama server (default http://localhost:11434), no key needed.
OLLAMA_BASE_URL=
# Optional eval-suite defaults (overridden by --provider / --judge-provider):
# which provider the evals run under, and which judges semantic must_contain checks.
EVAL_PROVIDER=
EVAL_JUDGE_PROVIDER=
EVAL_SAMPLES= # optional number of times to make eval call. Default is 1

